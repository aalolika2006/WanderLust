<!DOCTYPE html>
<html>
<head>
    <title>Error</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light d-flex align-items-center justify-content-center vh-100">

<div class="text-center p-5 shadow rounded bg-white" style="max-width: 500px; width: 100%;">

    <div class="text-danger display-1 fw-bold">⚠️</div>

    <h2 class="mb-3">Oops! Something went wrong</h2>

    <p class="text-muted mb-4">
        <%= message %>
    </p>

    <a href="/listings" class="btn btn-danger">
        Go Back Home
    </a>

</div>

</body>
</html>