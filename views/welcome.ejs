<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <div class="text-center">

        <h1 class="display-1 fw-bold text-danger">
            WanderLust 🌍
        </h1>

        <h2 class="mt-4">
            Welcome, <%= username %>!
        </h2>

        <p class="lead mt-3">
            Your account has been created successfully.
        </p>

        <p class="text-muted">
            Discover amazing places, share unforgettable experiences,
            and start your next adventure today.
        </p>

    </div>

    <div class="text-center mt-5">

        <img
            src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e"
            class="img-fluid rounded shadow"
            style="max-height:500px;"
        >

    </div>

    <div class="text-center mt-5">

        <a href="/listings" class="btn btn-danger btn-lg px-5 py-3">
            Begin Your Journey ✈️
        </a>

    </div>

</div>