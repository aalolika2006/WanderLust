<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h2>Welcome, <%= username %>! 🎉</h2>
        <p class="text-muted">Discover amazing places and start your next adventure.</p>
    </div>

    <div class="row g-2">
        <%# Big image left %>
        <div class="col-8">
            <div class="position-relative rounded-4 overflow-hidden" style="height: 450px;">
                <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e"
                    class="w-100 h-100" style="object-fit:cover; filter:brightness(0.6);">
                <div class="position-absolute bottom-0 start-0 p-4 text-white">
                    <h3 class="fw-bold">Your next adventure awaits</h3>
                    <a href="/listings" class="btn btn-danger rounded-pill px-4 mt-2">
                        Begin Your Journey ✈️
                    </a>
                </div>
            </div>
        </div>

        <%# 3 small images right %>
        <div class="col-4 d-flex flex-column g-2" style="gap: 8px;">
            <div class="rounded-4 overflow-hidden" style="height: 145px;">
                <img src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1"
                    class="w-100 h-100" style="object-fit:cover;">
            </div>
            <div class="rounded-4 overflow-hidden" style="height: 145px;">
                <img src="https://images.unsplash.com/photo-1469854523086-cc02fe5d8800"
                    class="w-100 h-100" style="object-fit:cover;">
            </div>
            <div class="rounded-4 overflow-hidden" style="height: 145px;">
                <img src="https://images.unsplash.com/photo-1530521954074-e64f6810b32d"
                    class="w-100 h-100" style="object-fit:cover;">
            </div>
        </div>
    </div>

</div>