<% layout("/layouts/boilerplate") %>

<div class="container mt-5 d-flex justify-content-center">

  <div class="card shadow-sm p-4" style="width: 600px;">

    <h3 class="mb-4 text-center">Add New Listing</h3>

    <form action="/listings" method="POST" class="row g-3 needs-validation" novalidate enctype="multipart/form-data">

      <div class="mb-3">
        <label class="form-label" >Title</label>
       
        <input id="title" type="text" name="listings[title]" class="form-control" required>
      </div>

    <textarea id="description" name="listings[description]" class="form-control" rows="4" required></textarea>

<button
    type="button"
    id="generateBtn"
    class="btn btn-outline-danger mt-2">
    ✨ Generate with AI
</button>

      <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input type="text" name="listings[image][url]" class="form-control">
      </div>
   <div class="mb-3">
        <label class="form-label">Upload Image</label>
        <input type="file" name="listings[image]" class="form-control">
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Price</label>
          <input type="number" name="listings[price]" class="form-control" required>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Country</label>
          <input type="text" name="listings[country]" class="form-control" required>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label" >Location</label>
        <input id="location" type="text" name="listings[location]" class="form-control" required>
      </div>

      <button class="btn btn-danger w-100 rounded-pill">
        Add Listing
      </button>

    </form>
    <script>

document.getElementById("generateBtn").addEventListener("click", async () => {

    const title = document.getElementById("title").value;
    const location = document.getElementById("location").value;

    if (!title || !location) {
        alert("Please enter title and location first.");
        return;
    }

    const btn = document.getElementById("generateBtn");

    btn.innerText = "Generating...";

    const res = await fetch("/generate-description", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
        },
        body: JSON.stringify({
            title,
            location,
        }),
    });

    const data = await res.json();

    document.getElementById("description").value = data.description;

    btn.innerText = "✨ Generate with AI";

});

</script>
<script src="/valid.js"></script>
  </div>
</div>